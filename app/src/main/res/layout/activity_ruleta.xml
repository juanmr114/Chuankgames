<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_degradado">

    <!-- Header (sin botón volver — lo ponemos abajo) -->
    <LinearLayout
        android:id="@+id/headerRuleta"
        android:layout_width="0dp"
        android:layout_height="52dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="@color/card_dark"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="16dp"
            android:text="🎰 Ruleta"
            android:textColor="@color/secundario"
            android:textSize="17sp"
            android:textStyle="bold"
            android:fontFamily="@font/orangekid" />

        <!-- CK disponibles -->
        <TextView
            android:id="@+id/tvSaldoRuleta"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="16dp"
            android:text="⚡ 0 CK"
            android:textColor="@color/secundario"
            android:textSize="13sp"
            android:textStyle="bold" />

    </LinearLayout>

    <!-- Contenido scrollable -->
    <androidx.core.widget.NestedScrollView
        android:id="@+id/scrollRuleta"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="@android:color/transparent"
        app:layout_constraintTop_toBottomOf="@id/headerRuleta"
        app:layout_constraintBottom_toTopOf="@id/lineaSeparadora"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="20dp"
            android:paddingTop="20dp"
            android:paddingBottom="12dp"
            android:gravity="center_horizontal">

            <!-- Indicador de precio encima de la ruleta -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:text="⚡ 50 CK por tirada"
                android:textColor="@color/texto_hint"
                android:textSize="12sp"
                android:gravity="center" />

            <!-- Círculo de la ruleta -->
            <FrameLayout
                android:id="@+id/frameRuleta"
                android:layout_width="260dp"
                android:layout_height="260dp">

                <!-- La rueda que gira -->
                <ImageView
                    android:id="@+id/ivRuleta"
                    android:layout_width="260dp"
                    android:layout_height="260dp"
                    android:src="@drawable/bg_circulo_ruleta"
                    android:scaleType="fitXY" />

                <!-- Contenido encima de la rueda (emoji + resultado) -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="vertical"
                    android:gravity="center">

                    <TextView
                        android:id="@+id/tvRuletaEmoji"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🎰"
                        android:textSize="72sp"
                        android:gravity="center" />

                    <TextView
                        android:id="@+id/tvResultadoRuleta"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="¡Gira!"
                        android:textColor="@color/secundario"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        android:gravity="center" />

                </LinearLayout>

            </FrameLayout>

            <!-- Botón GIRAR grande -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnGirar"
                android:layout_width="220dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:text="🎰  ¡GIRAR!"
                android:textColor="@color/principal"
                android:textSize="17sp"
                android:textStyle="bold"
                android:backgroundTint="@color/secundario"
                android:paddingVertical="16dp"
                app:cornerRadius="30dp" />

            <!-- Historial de tiradas -->
            <TextView
                android:id="@+id/tvHistorialRuleta"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:textColor="@color/texto_hint"
                android:textSize="12sp"
                android:gravity="center"
                android:lineSpacingMultiplier="1.6" />

            <!-- Tabla de premios -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                app:cardCornerRadius="14dp"
                app:cardBackgroundColor="@color/card_bg"
                app:cardElevation="6dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🏆 Premios posibles"
                        android:textColor="@color/white"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="12dp" />

                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginBottom="8dp">
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="🥉  €0.20" android:textColor="@color/texto_cuerpo" android:textSize="13sp" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="40%" android:textColor="@color/texto_hint" android:textSize="13sp" />
                    </LinearLayout>
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginBottom="8dp">
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="🥈  €0.50" android:textColor="@color/texto_cuerpo" android:textSize="13sp" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="25%" android:textColor="@color/texto_hint" android:textSize="13sp" />
                    </LinearLayout>
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginBottom="8dp">
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="🥇  €1.00" android:textColor="@color/texto_cuerpo" android:textSize="13sp" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="20%" android:textColor="@color/texto_hint" android:textSize="13sp" />
                    </LinearLayout>
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginBottom="8dp">
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="💎  €5.00" android:textColor="@color/secundario" android:textSize="13sp" android:textStyle="bold" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="10%" android:textColor="@color/texto_hint" android:textSize="13sp" />
                    </LinearLayout>
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginBottom="8dp">
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="👑  €10.00" android:textColor="@color/secundario" android:textSize="13sp" android:textStyle="bold" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="4%" android:textColor="@color/texto_hint" android:textSize="13sp" />
                    </LinearLayout>
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal">
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="🌟  €20.00" android:textColor="@color/verde_bonus" android:textSize="13sp" android:textStyle="bold" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="1%" android:textColor="@color/texto_hint" android:textSize="13sp" />
                    </LinearLayout>

                </LinearLayout>

            </androidx.cardview.widget.CardView>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- Línea separadora -->
    <View
        android:id="@+id/lineaSeparadora"
        android:layout_width="0dp"
        android:layout_height="3dp"
        android:background="@color/secundario"
        app:layout_constraintBottom_toTopOf="@id/bottomNav"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Bottom Navigation -->
    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottomNav"
        android:layout_width="0dp"
        android:layout_height="70dp"
        android:background="@color/principal"
        app:itemIconTint="@color/bottom_nav_color"
        app:itemTextColor="@color/bottom_nav_color"
        app:menu="@menu/menu_bottom_nav"
        app:labelVisibilityMode="labeled"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
