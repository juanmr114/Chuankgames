<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_degradado">

    <!-- ══════════════════════════════════════
         CONTENIDO SCROLLABLE
         ══════════════════════════════════════ -->
    <androidx.core.widget.NestedScrollView
        android:id="@+id/scrollRuleta"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="@android:color/transparent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/lineaSeparadora"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:paddingHorizontal="18dp"
            android:paddingTop="22dp"
            android:paddingBottom="14dp">

            <!-- ── Título ── -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🎰 Ruleta"
                android:textColor="@color/secundario"
                android:textSize="32sp"
                android:textStyle="bold"
                android:fontFamily="@font/orangekid"
                android:gravity="center" />

            <!-- ── Chip saldo CK ── -->
            <TextView
                android:id="@+id/tvSaldoRuleta"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="⚡ 0 CK"
                android:textColor="@color/principal"
                android:textSize="15sp"
                android:textStyle="bold"
                android:background="@drawable/bg_chip_ck"
                android:paddingHorizontal="18dp"
                android:paddingVertical="7dp" />

            <!-- ── Coste por tirada ── -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="⚡ 100 CK por tirada"
                android:textColor="@color/texto_hint"
                android:textSize="12sp"
                android:gravity="center" />

            <!-- ══════════════════════════════════════
                 ZONA DE RULETA CON ANILLO DORADO
                 ══════════════════════════════════════ -->
            <FrameLayout
                android:layout_width="300dp"
                android:layout_height="300dp"
                android:layout_marginTop="24dp">

                <!-- Anillo dorado exterior -->
                <View
                    android:layout_width="300dp"
                    android:layout_height="300dp"
                    android:layout_gravity="center"
                    android:background="@drawable/bg_ring_dorado" />

                <!-- Segundo anillo (más pequeño, efecto doble aro) -->
                <View
                    android:layout_width="288dp"
                    android:layout_height="288dp"
                    android:layout_gravity="center"
                    android:background="@drawable/bg_ring_dorado"
                    android:alpha="0.35" />

                <!-- La rueda giratoria -->
                <ImageView
                    android:id="@+id/ivRuleta"
                    android:layout_width="278dp"
                    android:layout_height="278dp"
                    android:layout_gravity="center"
                    android:src="@drawable/bg_circulo_ruleta"
                    android:scaleType="fitXY" />

                <!-- Emoji + resultado superpuestos en el centro -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="vertical"
                    android:gravity="center">

                    <TextView
                        android:id="@+id/tvRuletaEmoji"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🎰"
                        android:textSize="68sp"
                        android:gravity="center" />

                    <TextView
                        android:id="@+id/tvResultadoRuleta"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:text="¡Gira!"
                        android:textColor="@color/secundario"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        android:gravity="center"
                        android:fontFamily="@font/orangekid" />

                </LinearLayout>
            </FrameLayout>

            <!-- ── Botón GIRAR (grande y llamativo) ── -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnGirar"
                android:layout_width="match_parent"
                android:layout_height="58dp"
                android:layout_marginTop="26dp"
                android:text="🎰  ¡GIRAR!"
                android:textColor="@color/principal"
                android:textSize="18sp"
                android:textStyle="bold"
                android:backgroundTint="@color/secundario"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:letterSpacing="0.05"
                app:cornerRadius="29dp" />

            <!-- ── Historial de últimas tiradas ── -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                app:cardCornerRadius="14dp"
                app:cardBackgroundColor="@color/card_bg"
                app:cardElevation="4dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingHorizontal="14dp"
                    android:paddingVertical="12dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="ÚLTIMAS TIRADAS"
                        android:textColor="@color/texto_hint"
                        android:textSize="10sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.12"
                        android:layout_marginBottom="6dp" />

                    <TextView
                        android:id="@+id/tvHistorialRuleta"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textColor="@color/secundario"
                        android:textSize="14sp"
                        android:gravity="center"
                        android:lineSpacingMultiplier="1.5"
                        android:text="—" />

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- ── Tabla de premios ── -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                app:cardCornerRadius="16dp"
                app:cardBackgroundColor="@color/card_bg"
                app:cardElevation="4dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🏆 Premios posibles"
                        android:textColor="@color/white"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:fontFamily="@font/orangekid"
                        android:layout_marginBottom="14dp" />

                    <!-- Fila premio: 🥉 -->
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="10dp">
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="🥉  €0.50" android:textColor="@color/texto_cuerpo" android:textSize="14sp" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="40%" android:textColor="@color/texto_hint" android:textSize="12sp" android:background="@drawable/bg_chip_genero" android:paddingHorizontal="8dp" android:paddingVertical="3dp" />
                    </LinearLayout>

                    <!-- Fila premio: 🥈 -->
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="10dp">
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="🥈  €1.00" android:textColor="@color/texto_cuerpo" android:textSize="14sp" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="25%" android:textColor="@color/texto_hint" android:textSize="12sp" android:background="@drawable/bg_chip_genero" android:paddingHorizontal="8dp" android:paddingVertical="3dp" />
                    </LinearLayout>

                    <!-- Fila premio: 🥇 -->
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="10dp">
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="🥇  €3.00" android:textColor="@color/texto_cuerpo" android:textSize="14sp" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="20%" android:textColor="@color/texto_hint" android:textSize="12sp" android:background="@drawable/bg_chip_genero" android:paddingHorizontal="8dp" android:paddingVertical="3dp" />
                    </LinearLayout>

                    <!-- Separador visual antes de los premios grandes -->
                    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="@color/secundario_alpha" android:layout_marginBottom="10dp" />

                    <!-- Fila premio: 💎 -->
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="10dp">
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="💎  €10.00" android:textColor="@color/secundario" android:textSize="14sp" android:textStyle="bold" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="10%" android:textColor="@color/texto_hint" android:textSize="12sp" android:background="@drawable/bg_chip_genero" android:paddingHorizontal="8dp" android:paddingVertical="3dp" />
                    </LinearLayout>

                    <!-- Fila premio: 👑 -->
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="10dp">
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="👑  €20.00" android:textColor="@color/secundario" android:textSize="14sp" android:textStyle="bold" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="4%" android:textColor="@color/texto_hint" android:textSize="12sp" android:background="@drawable/bg_chip_genero" android:paddingHorizontal="8dp" android:paddingVertical="3dp" />
                    </LinearLayout>

                    <!-- Fila premio: 🌟 JACKPOT -->
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical">
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="🌟  €30.00  JACKPOT" android:textColor="@color/verde_bonus" android:textSize="14sp" android:textStyle="bold" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="1%" android:textColor="@color/texto_hint" android:textSize="12sp" android:background="@drawable/bg_chip_genero" android:paddingHorizontal="8dp" android:paddingVertical="3dp" />
                    </LinearLayout>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- Línea separadora -->
    <View
        android:id="@+id/lineaSeparadora"
        android:layout_width="0dp"
        android:layout_height="3dp"
        android:background="@color/secundario"
        app:layout_constraintBottom_toTopOf="@id/bottomNav"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Bottom Navigation -->
    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottomNav"
        android:layout_width="0dp"
        android:layout_height="70dp"
        android:background="@color/principal"
        app:itemIconTint="@color/bottom_nav_color"
        app:itemTextColor="@color/bottom_nav_color"
        app:menu="@menu/menu_bottom_nav"
        app:labelVisibilityMode="labeled"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
