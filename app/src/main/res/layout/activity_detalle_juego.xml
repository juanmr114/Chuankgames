<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_degradado">

    <!-- Header bar (sin botón volver — está abajo) -->
    <LinearLayout
        android:id="@+id/headerDetalle"
        android:layout_width="0dp"
        android:layout_height="52dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="@color/card_dark"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:id="@+id/tvHeaderNombre"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="8dp"
            android:textColor="@color/white"
            android:textSize="15sp"
            android:textStyle="bold"
            android:maxLines="1"
            android:ellipsize="end" />

        <!-- Saldo compacto -->
        <TextView
            android:id="@+id/tvSaldoDetalle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="12dp"
            android:text="💶 0€"
            android:textColor="@color/secundario"
            android:textSize="12sp"
            android:textStyle="bold" />

    </LinearLayout>

    <!-- Contenido scrollable -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="@android:color/transparent"
        app:layout_constraintTop_toBottomOf="@id/headerDetalle"
        app:layout_constraintBottom_toTopOf="@id/btnVolverDetalle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Imagen portada -->
            <ImageView
                android:id="@+id/ivDetallePortada"
                android:layout_width="match_parent"
                android:layout_height="210dp"
                android:scaleType="centerCrop"
                android:background="@color/card_dark" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <!-- Nombre -->
                <TextView
                    android:id="@+id/tvDetalleNombre"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="@color/secundario"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    android:fontFamily="@font/orangekid" />

                <!-- Género y vendedor -->
                <TextView
                    android:id="@+id/tvDetalleGenero"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:textColor="@color/texto_hint"
                    android:textSize="13sp" />

                <TextView
                    android:id="@+id/tvDetalleVendedor"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:textColor="@color/texto_hint"
                    android:textSize="13sp" />

                <!-- Descripción -->
                <TextView
                    android:id="@+id/tvDetalleDescripcion"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:textColor="@color/texto_cuerpo"
                    android:textSize="14sp"
                    android:lineSpacingMultiplier="1.4" />

                <!-- Separador -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@color/secundario_alpha"
                    android:layout_marginTop="18dp"
                    android:layout_marginBottom="16dp" />

                <!-- Precios -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/tvDetallePrecio"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textColor="@color/secundario"
                            android:textSize="26sp"
                            android:textStyle="bold"
                            android:fontFamily="@font/orangekid" />

                        <TextView
                            android:id="@+id/tvDetallePrecioEuro"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textColor="@color/texto_hint"
                            android:textSize="13sp" />

                    </LinearLayout>

                    <!-- Bonus CK -->
                    <TextView
                        android:id="@+id/tvCKReward"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:background="@color/card_bg"
                        android:paddingHorizontal="10dp"
                        android:paddingVertical="6dp"
                        android:textColor="@color/verde_bonus"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:gravity="center"
                        android:visibility="gone" />

                </LinearLayout>

                <!-- Botón comprar con € -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnComprarEuro"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:text="🏦 Comprar con €0.00"
                    android:textColor="@color/principal"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:backgroundTint="@color/secundario"
                    android:paddingVertical="14dp"
                    app:cornerRadius="12dp" />

                <!-- Botón revender -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnRevender"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="🔄 Poner en venta"
                    android:textColor="@color/texto_hint"
                    android:textSize="14sp"
                    android:backgroundTint="@color/card_bg"
                    android:paddingVertical="12dp"
                    android:visibility="gone"
                    app:cornerRadius="12dp"
                    app:strokeColor="@color/card_border"
                    app:strokeWidth="1dp" />

                <ProgressBar
                    android:id="@+id/progressDetalle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center_horizontal"
                    android:layout_marginTop="12dp"
                    android:visibility="gone" />

            </LinearLayout>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- Botón VOLVER fijo en la parte inferior (fácil de pulsar) -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnVolverDetalle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="16dp"
        android:layout_marginBottom="16dp"
        android:text="← Volver"
        android:textColor="@color/secundario"
        android:textSize="15sp"
        android:textStyle="bold"
        android:backgroundTint="@color/card_dark"
        android:paddingVertical="14dp"
        app:cornerRadius="28dp"
        app:strokeColor="@color/secundario"
        app:strokeWidth="1dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
