<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/drawerLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- ===== CONTENIDO PRINCIPAL ===== -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/bg_degradado">

        <!-- Botón hamburguesa -->
        <ImageView
            android:id="@+id/btnMenu"
            android:layout_width="38dp"
            android:layout_height="38dp"
            android:layout_marginTop="14dp"
            android:layout_marginStart="14dp"
            android:src="@android:drawable/ic_menu_sort_by_size"
            android:tint="@color/secundario"
            android:padding="4dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent" />

        <!-- Botón cerrar sesión — icono apagar (top-right, ARRIBA del saldo) -->
        <ImageView
            android:id="@+id/btnCerrarSesion"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:layout_marginTop="14dp"
            android:layout_marginEnd="18dp"
            android:src="@android:drawable/ic_lock_power_off"
            android:tint="#FF5555"
            android:padding="4dp"
            android:clickable="true"
            android:focusable="true"
            android:background="?attr/selectableItemBackgroundBorderless"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Chip saldo (top-right, debajo del botón de apagado) -->
        <TextView
            android:id="@+id/tvSaldoPrincipal"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:layout_marginEnd="14dp"
            android:text="⚡ 0 CK"
            android:textColor="@color/principal"
            android:textSize="12sp"
            android:textStyle="bold"
            android:background="@drawable/bg_chip_ck"
            android:paddingHorizontal="12dp"
            android:paddingVertical="5dp"
            android:clickable="true"
            android:focusable="true"
            app:layout_constraintTop_toBottomOf="@id/btnCerrarSesion"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Logo (se coloca debajo del elemento más bajo del top-bar) -->
        <ImageView
            android:id="@+id/ivLogoPrincipal"
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:layout_marginTop="10dp"
            android:scaleType="fitCenter"
            android:src="@mipmap/ic_launcher"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tvSaldoPrincipal" />

        <!-- Título -->
        <TextView
            android:id="@+id/tvTituloPrincipal"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="Chuankgames"
            android:textColor="@color/secundario"
            android:textSize="30sp"
            android:textStyle="bold"
            android:fontFamily="@font/orangekid"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/ivLogoPrincipal" />

        <!-- Barra de búsqueda -->
        <EditText
            android:id="@+id/etBuscar"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_marginTop="10dp"
            android:layout_marginHorizontal="16dp"
            android:hint="🔍 Buscar videojuego..."
            android:background="@drawable/bg_campo_busqueda"
            android:textColor="@color/white"
            android:textColorHint="#88FFFFFF"
            android:paddingHorizontal="16dp"
            android:inputType="text"
            android:imeOptions="actionSearch"
            android:singleLine="true"
            android:textSize="14sp"
            app:layout_constraintTop_toBottomOf="@id/tvTituloPrincipal"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- ── Separador estilo nav-bar ── -->
        <View
            android:id="@+id/separadorNavBar"
            android:layout_width="0dp"
            android:layout_height="1dp"
            android:layout_marginTop="10dp"
            android:background="@color/secundario"
            android:alpha="0.35"
            app:layout_constraintTop_toBottomOf="@id/etBuscar"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- ── Filtro por género ── -->
        <HorizontalScrollView
            android:id="@+id/scrollFiltroGenero"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:scrollbars="none"
            android:fadingEdgeLength="16dp"
            android:requiresFadingEdge="horizontal"
            app:layout_constraintTop_toBottomOf="@id/separadorNavBar"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <LinearLayout
                android:id="@+id/layoutChipsGenero"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingHorizontal="12dp"
                android:paddingVertical="4dp" />

        </HorizontalScrollView>

        <!-- ── Filtro por precio ── -->
        <HorizontalScrollView
            android:id="@+id/scrollFiltroPrecio"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:scrollbars="none"
            android:fadingEdgeLength="16dp"
            android:requiresFadingEdge="horizontal"
            app:layout_constraintTop_toBottomOf="@id/scrollFiltroGenero"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <LinearLayout
                android:id="@+id/layoutChipsPrecio"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingHorizontal="12dp"
                android:paddingVertical="4dp" />

        </HorizontalScrollView>

        <!-- Scroll con las dos secciones -->
        <androidx.core.widget.NestedScrollView
            android:id="@+id/scrollContenido"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_marginTop="4dp"
            android:clipToPadding="false"
            app:layout_constraintTop_toBottomOf="@id/scrollFiltroPrecio"
            app:layout_constraintBottom_toTopOf="@id/lineaSeparadora"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingBottom="8dp">

                <!-- SECCIÓN: Todos los videojuegos -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingHorizontal="16dp"
                    android:paddingVertical="10dp">

                    <View
                        android:layout_width="4dp"
                        android:layout_height="22dp"
                        android:background="@color/secundario"
                        android:layout_marginEnd="10dp" />

                    <TextView
                        android:id="@+id/tvTituloTodos"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Todos los videojuegos"
                        android:textColor="@color/white"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:fontFamily="@font/orangekid" />

                </LinearLayout>

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/recyclerTodos"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:nestedScrollingEnabled="false"
                    app:layoutManager="androidx.recyclerview.widget.GridLayoutManager"
                    app:spanCount="2"
                    android:paddingHorizontal="8dp" />

                <!-- Empty state Todos -->
                <TextView
                    android:id="@+id/tvEmptyTodos"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="No hay juegos disponibles aún"
                    android:textColor="@color/texto_hint"
                    android:textSize="13sp"
                    android:gravity="center"
                    android:padding="20dp"
                    android:visibility="gone" />

                <!-- Separador entre secciones -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@color/secundario_alpha"
                    android:layout_marginHorizontal="16dp"
                    android:layout_marginTop="16dp"
                    android:layout_marginBottom="4dp" />

                <!-- SECCIÓN: Tus juegos -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingHorizontal="16dp"
                    android:paddingVertical="10dp">

                    <View
                        android:layout_width="4dp"
                        android:layout_height="22dp"
                        android:background="@color/secundario"
                        android:layout_marginEnd="10dp" />

                    <TextView
                        android:id="@+id/tvTituloRecomendados"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Juegos que tengo en venta"
                        android:textColor="@color/white"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:fontFamily="@font/orangekid" />

                </LinearLayout>

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/recyclerRecomendados"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:nestedScrollingEnabled="false"
                    android:paddingHorizontal="8dp"
                    android:paddingBottom="8dp" />

                <!-- Empty state Propios -->
                <TextView
                    android:id="@+id/tvEmptyPropios"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Aún no has publicado ningún juego\n¡Pulsa + para publicar el primero!"
                    android:textColor="@color/texto_hint"
                    android:textSize="13sp"
                    android:gravity="center"
                    android:padding="20dp"
                    android:visibility="gone" />

            </LinearLayout>
        </androidx.core.widget.NestedScrollView>

        <!-- Línea separadora -->
        <View
            android:id="@+id/lineaSeparadora"
            android:layout_width="0dp"
            android:layout_height="3dp"
            android:background="@color/secundario"
            app:layout_constraintBottom_toTopOf="@id/bottomNav"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent" />

        <!-- Bottom Navigation -->
        <com.google.android.material.bottomnavigation.BottomNavigationView
            android:id="@+id/bottomNav"
            android:layout_width="0dp"
            android:layout_height="70dp"
            android:background="@color/principal"
            app:itemIconTint="@color/bottom_nav_color"
            app:itemTextColor="@color/bottom_nav_color"
            app:menu="@menu/menu_bottom_nav"
            app:labelVisibilityMode="labeled"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- ===== MENÚ LATERAL (Drawer) ===== -->
    <com.google.android.material.navigation.NavigationView
        android:id="@+id/navigationView"
        android:layout_width="280dp"
        android:layout_height="match_parent"
        android:layout_gravity="start"
        android:background="@color/principal"
        app:headerLayout="@layout/nav_header"
        app:menu="@menu/menu_lateral"
        app:itemTextColor="@color/white"
        app:itemIconTint="@color/secundario" />

</androidx.drawerlayout.widget.DrawerLayout>
