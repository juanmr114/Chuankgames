<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/drawerLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- ===== CONTENIDO PRINCIPAL ===== -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/bg_degradado">

        <!-- Botón hamburguesa -->
        <ImageView
            android:id="@+id/btnMenu"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:layout_marginTop="16dp"
            android:layout_marginStart="16dp"
            android:src="@android:drawable/ic_menu_sort_by_size"
            android:tint="@color/secundario"
            android:padding="4dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent" />

        <!-- Logo -->
        <ImageView
            android:id="@+id/ivLogoPrincipal"
            android:layout_width="90dp"
            android:layout_height="90dp"
            android:layout_marginTop="16dp"
            android:scaleType="centerCrop"
            android:src="@mipmap/ic_launcher"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <!-- Título -->
        <TextView
            android:id="@+id/tvTituloPrincipal"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Mis videojuegos"
            android:textColor="@color/secundario"
            android:textSize="32sp"
            android:textStyle="bold"
            android:fontFamily="@font/orangekid"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/ivLogoPrincipal" />

        <!-- Barra de búsqueda -->
        <EditText
            android:id="@+id/etBuscar"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_marginTop="12dp"
            android:layout_marginHorizontal="16dp"
            android:hint="🔍 Buscar videojuego..."
            android:background="@drawable/bg_campo_busqueda"
            android:textColor="@color/white"
            android:textColorHint="#88FFFFFF"
            android:paddingHorizontal="16dp"
            android:inputType="text"
            android:imeOptions="actionSearch"
            android:singleLine="true"
            android:textSize="14sp"
            app:layout_constraintTop_toBottomOf="@id/tvTituloPrincipal"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Scroll con las dos secciones -->
        <androidx.core.widget.NestedScrollView
            android:id="@+id/scrollContenido"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_marginTop="8dp"
            android:clipToPadding="false"
            app:layout_constraintTop_toBottomOf="@id/etBuscar"
            app:layout_constraintBottom_toTopOf="@id/lineaSeparadora"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <!-- SECCIÓN: Todos los videojuegos -->
                <TextView
                    android:id="@+id/tvTituloTodos"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🎮 Todos los videojuegos"
                    android:textColor="@color/secundario"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:fontFamily="@font/orangekid"
                    android:paddingHorizontal="16dp"
                    android:paddingBottom="8dp" />

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/recyclerTodos"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:nestedScrollingEnabled="false"
                    app:layoutManager="androidx.recyclerview.widget.GridLayoutManager"
                    app:spanCount="2"
                    android:paddingHorizontal="8dp" />

                <!-- Separador entre secciones -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="2dp"
                    android:background="@color/secundario"
                    android:layout_marginHorizontal="16dp"
                    android:layout_marginTop="20dp"
                    android:layout_marginBottom="16dp" />

                <!-- SECCIÓN: Recomendados -->
                <TextView
                    android:id="@+id/tvTituloRecomendados"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="👤 Tus videojuegos creados"
                    android:textColor="@color/secundario"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:fontFamily="@font/orangekid"
                    android:paddingHorizontal="16dp"
                    android:paddingBottom="8dp" />

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/recyclerRecomendados"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:nestedScrollingEnabled="false"
                    android:paddingHorizontal="8dp"
                    android:paddingBottom="16dp" />

            </LinearLayout>
        </androidx.core.widget.NestedScrollView>

        <!-- Línea separadora -->
        <View
            android:id="@+id/lineaSeparadora"
            android:layout_width="0dp"
            android:layout_height="3dp"
            android:background="@color/secundario"
            app:layout_constraintBottom_toTopOf="@id/bottomNav"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent" />

        <!-- Bottom Navigation -->
        <com.google.android.material.bottomnavigation.BottomNavigationView
            android:id="@+id/bottomNav"
            android:layout_width="0dp"
            android:layout_height="70dp"
            android:background="@color/principal"
            app:itemIconTint="@color/bottom_nav_color"
            app:itemTextColor="@color/bottom_nav_color"
            app:menu="@menu/menu_bottom_nav"
            app:labelVisibilityMode="labeled"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- ===== MENÚ LATERAL (Drawer) ===== -->
    <com.google.android.material.navigation.NavigationView
        android:id="@+id/navigationView"
        android:layout_width="280dp"
        android:layout_height="match_parent"
        android:layout_gravity="start"
        android:background="@color/principal"
        app:headerLayout="@layout/nav_header"
        app:menu="@menu/menu_lateral"
        app:itemTextColor="@color/white"
        app:itemIconTint="@color/secundario" />

</androidx.drawerlayout.widget.DrawerLayout>