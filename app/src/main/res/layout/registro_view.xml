<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_degradado"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:paddingHorizontal="26dp"
        android:paddingTop="48dp"
        android:paddingBottom="36dp">

        <!-- ── Mini-logo ── -->
        <ImageView
            android:layout_width="76dp"
            android:layout_height="76dp"
            android:src="@mipmap/ic_launcher"
            android:scaleType="fitCenter" />

        <!-- ── Nombre ── -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Chuankgames"
            android:textColor="@color/secundario"
            android:textSize="26sp"
            android:textStyle="bold"
            android:fontFamily="@font/orangekid" />

        <!-- ── Separador ── -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="✦   ✦   ✦"
            android:textColor="@color/secundario_alpha"
            android:textSize="10sp"
            android:letterSpacing="0.3" />

        <!-- ══════════════════════════════════════
             CARD DEL FORMULARIO
             ══════════════════════════════════════ -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            app:cardCornerRadius="22dp"
            app:cardBackgroundColor="@color/card_bg"
            app:cardElevation="18dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="26dp">

                <!-- Título -->
                <TextView
                    android:id="@+id/tvTituloRegistro"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Crear cuenta"
                    android:textColor="@color/white"
                    android:textSize="21sp"
                    android:textStyle="bold"
                    android:fontFamily="@font/orangekid"
                    android:layout_marginBottom="20dp" />

                <!-- Campo Nombre -->
                <com.google.android.material.textfield.TextInputLayout
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Nombre completo"
                    app:startIconDrawable="@android:drawable/ic_menu_myplaces"
                    app:startIconTint="@color/secundario"
                    app:boxStrokeColor="@color/secundario"
                    app:hintTextColor="@color/texto_hint"
                    app:boxCornerRadiusTopStart="12dp"
                    app:boxCornerRadiusTopEnd="12dp"
                    app:boxCornerRadiusBottomStart="12dp"
                    app:boxCornerRadiusBottomEnd="12dp">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etNombre"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="textPersonName"
                        android:textColor="@color/white" />

                </com.google.android.material.textfield.TextInputLayout>

                <!-- Campo Email -->
                <com.google.android.material.textfield.TextInputLayout
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:hint="Correo electrónico"
                    app:startIconDrawable="@drawable/ic_email"
                    app:startIconTint="@color/secundario"
                    app:boxStrokeColor="@color/secundario"
                    app:hintTextColor="@color/texto_hint"
                    app:boxCornerRadiusTopStart="12dp"
                    app:boxCornerRadiusTopEnd="12dp"
                    app:boxCornerRadiusBottomStart="12dp"
                    app:boxCornerRadiusBottomEnd="12dp">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etEmail"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="textEmailAddress"
                        android:textColor="@color/white" />

                </com.google.android.material.textfield.TextInputLayout>

                <!-- Campo Contraseña -->
                <com.google.android.material.textfield.TextInputLayout
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:hint="Contraseña"
                    app:startIconDrawable="@drawable/ic_password"
                    app:startIconTint="@color/secundario"
                    app:endIconMode="password_toggle"
                    app:endIconTint="@color/secundario"
                    app:boxStrokeColor="@color/secundario"
                    app:hintTextColor="@color/texto_hint"
                    app:boxCornerRadiusTopStart="12dp"
                    app:boxCornerRadiusTopEnd="12dp"
                    app:boxCornerRadiusBottomStart="12dp"
                    app:boxCornerRadiusBottomEnd="12dp">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etPassword"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="textPassword"
                        android:textColor="@color/white" />

                </com.google.android.material.textfield.TextInputLayout>

                <!-- Campo Confirmar contraseña -->
                <com.google.android.material.textfield.TextInputLayout
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:hint="Confirmar contraseña"
                    app:startIconDrawable="@drawable/ic_password"
                    app:startIconTint="@color/secundario"
                    app:endIconMode="password_toggle"
                    app:endIconTint="@color/secundario"
                    app:boxStrokeColor="@color/secundario"
                    app:hintTextColor="@color/texto_hint"
                    app:boxCornerRadiusTopStart="12dp"
                    app:boxCornerRadiusTopEnd="12dp"
                    app:boxCornerRadiusBottomStart="12dp"
                    app:boxCornerRadiusBottomEnd="12dp">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etConfirmarPassword"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="textPassword"
                        android:textColor="@color/white" />

                </com.google.android.material.textfield.TextInputLayout>

                <!-- Mensaje de bienvenida (50€ de regalo) -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:background="@color/card_dark"
                    android:padding="12dp"
                    android:layout_marginTop="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🎁"
                        android:textSize="20sp"
                        android:layout_marginEnd="10dp" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="¡Recibe 50€ de bienvenida para empezar a comprar!"
                        android:textColor="@color/verde_bonus"
                        android:textSize="12sp"
                        android:textStyle="bold" />

                </LinearLayout>

                <!-- Botón Registrarse -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnRegistrar"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="22dp"
                    android:text="🚀  Crear mi cuenta"
                    android:textColor="@color/principal"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:backgroundTint="@color/secundario"
                    android:paddingVertical="14dp"
                    app:cornerRadius="12dp" />

                <!-- Separador -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginTop="18dp">

                    <View
                        android:layout_width="0dp"
                        android:layout_height="1dp"
                        android:layout_weight="1"
                        android:background="@color/card_border" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:paddingHorizontal="14dp"
                        android:text="o"
                        android:textColor="@color/texto_hint"
                        android:textSize="13sp" />

                    <View
                        android:layout_width="0dp"
                        android:layout_height="1dp"
                        android:layout_weight="1"
                        android:background="@color/card_border" />

                </LinearLayout>

                <!-- Volver al login -->
                <TextView
                    android:id="@+id/tvVolverLogin"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:text="¿Ya tienes cuenta? Inicia sesión"
                    android:textColor="@color/secundario"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:gravity="center"
                    android:paddingVertical="14dp"
                    android:background="@drawable/bg_btn_outline" />

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Pie decorativo -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="★  Chuankgames  ★"
            android:textColor="@color/secundario_alpha"
            android:textSize="11sp"
            android:fontFamily="@font/orangekid"
            android:letterSpacing="0.15" />

    </LinearLayout>

</ScrollView>
