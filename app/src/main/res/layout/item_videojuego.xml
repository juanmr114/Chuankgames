<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="6dp"
    app:cardCornerRadius="14dp"
    app:cardBackgroundColor="@color/card_bg"
    app:cardElevation="6dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Imagen + badge de género encima -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="130dp">

            <ImageView
                android:id="@+id/imgJuego"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:background="@color/card_dark" />

            <!-- Badge género (top-start) -->
            <TextView
                android:id="@+id/tvGeneroJuego"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="top|start"
                android:layout_margin="6dp"
                android:background="@drawable/bg_chip_genero"
                android:paddingHorizontal="8dp"
                android:paddingVertical="3dp"
                android:textColor="@color/secundario"
                android:textSize="10sp"
                android:textStyle="bold" />

        </FrameLayout>

        <!-- Info inferior -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="10dp"
            android:paddingTop="8dp"
            android:paddingBottom="10dp">

            <TextView
                android:id="@+id/tvNombreJuego"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/white"
                android:textSize="13sp"
                android:textStyle="bold"
                android:maxLines="1"
                android:ellipsize="end" />

            <!-- Descripción (oculta, para compatibilidad con el adapter) -->
            <TextView
                android:id="@+id/tvDescripcionJuego"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/texto_cuerpo"
                android:textSize="10sp"
                android:maxLines="1"
                android:ellipsize="end"
                android:layout_marginTop="2dp"
                android:visibility="gone" />

            <!-- Chip precio -->
            <TextView
                android:id="@+id/tvPrecioJuego"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:background="@drawable/bg_chip_ck"
                android:paddingHorizontal="10dp"
                android:paddingVertical="3dp"
                android:textColor="@color/principal"
                android:textSize="11sp"
                android:textStyle="bold" />

            <!-- Botón código de activación (solo visible en Biblioteca) -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnVerCodigo"
                android:layout_width="match_parent"
                android:layout_height="32dp"
                android:layout_marginTop="7dp"
                android:text="🔑 Ver código"
                android:textColor="@color/principal"
                android:textSize="11sp"
                android:textStyle="bold"
                android:backgroundTint="@color/secundario"
                android:paddingVertical="0dp"
                app:cornerRadius="16dp"
                android:visibility="gone" />

        </LinearLayout>
    </LinearLayout>

</androidx.cardview.widget.CardView>
