<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_degradado"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:paddingHorizontal="26dp"
        android:paddingTop="56dp"
        android:paddingBottom="36dp">

        <!-- ── Logo ── -->
        <ImageView
            android:id="@+id/imgLogo"
            android:layout_width="120dp"
            android:layout_height="120dp"
            android:src="@mipmap/ic_launcher"
            android:scaleType="fitCenter" />

        <!-- ── Nombre de la app ── -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="Chuankgames"
            android:textColor="@color/secundario"
            android:textSize="34sp"
            android:textStyle="bold"
            android:fontFamily="@font/orangekid" />

        <!-- ── Tagline ── -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="🎮 Tu mercado de videojuegos"
            android:textColor="@color/texto_hint"
            android:textSize="13sp" />

        <!-- ── Separador decorativo pixel ── -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="22dp"
            android:text="✦   ✦   ✦"
            android:textColor="@color/secundario_alpha"
            android:textSize="11sp"
            android:letterSpacing="0.3" />

        <!-- ══════════════════════════════════════
             CARD DEL FORMULARIO
             ══════════════════════════════════════ -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            app:cardCornerRadius="22dp"
            app:cardBackgroundColor="@color/card_bg"
            app:cardElevation="18dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="26dp">

                <!-- Título del card -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Iniciar sesión"
                    android:textColor="@color/white"
                    android:textSize="21sp"
                    android:textStyle="bold"
                    android:fontFamily="@font/orangekid"
                    android:layout_marginBottom="20dp" />

                <!-- Campo Email -->
                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/tilEmail"
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Correo electrónico"
                    app:startIconDrawable="@drawable/ic_email"
                    app:startIconTint="@color/secundario"
                    app:boxStrokeColor="@color/secundario"
                    app:hintTextColor="@color/texto_hint"
                    app:boxCornerRadiusTopStart="12dp"
                    app:boxCornerRadiusTopEnd="12dp"
                    app:boxCornerRadiusBottomStart="12dp"
                    app:boxCornerRadiusBottomEnd="12dp">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etEmail"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="textEmailAddress"
                        android:textColor="@color/white" />

                </com.google.android.material.textfield.TextInputLayout>

                <!-- Campo Contraseña -->
                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/tilPassword"
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:hint="Contraseña"
                    app:startIconDrawable="@drawable/ic_password"
                    app:startIconTint="@color/secundario"
                    app:endIconMode="password_toggle"
                    app:endIconTint="@color/secundario"
                    app:boxStrokeColor="@color/secundario"
                    app:hintTextColor="@color/texto_hint"
                    app:boxCornerRadiusTopStart="12dp"
                    app:boxCornerRadiusTopEnd="12dp"
                    app:boxCornerRadiusBottomStart="12dp"
                    app:boxCornerRadiusBottomEnd="12dp">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etPassword"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="textPassword"
                        android:textColor="@color/white" />

                </com.google.android.material.textfield.TextInputLayout>

                <!-- ¿Olvidaste contraseña? -->
                <TextView
                    android:id="@+id/tvForgot"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="end"
                    android:layout_marginTop="10dp"
                    android:text="¿Olvidaste tu contraseña?"
                    android:textColor="@color/secundario"
                    android:textSize="12sp" />

                <!-- Botón Iniciar sesión -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnLogin"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="24dp"
                    android:text="🎮  Iniciar sesión"
                    android:textColor="@color/principal"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:backgroundTint="@color/secundario"
                    android:paddingVertical="14dp"
                    app:cornerRadius="12dp" />

                <!-- Separador ─── o ─── -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginTop="20dp">

                    <View
                        android:layout_width="0dp"
                        android:layout_height="1dp"
                        android:layout_weight="1"
                        android:background="@color/card_border" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:paddingHorizontal="14dp"
                        android:text="o"
                        android:textColor="@color/texto_hint"
                        android:textSize="13sp" />

                    <View
                        android:layout_width="0dp"
                        android:layout_height="1dp"
                        android:layout_weight="1"
                        android:background="@color/card_border" />

                </LinearLayout>

                <!-- Botón Crear cuenta (outlined) -->
                <TextView
                    android:id="@+id/tvRegister"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:text="Crear cuenta nueva"
                    android:textColor="@color/secundario"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:gravity="center"
                    android:paddingVertical="14dp"
                    android:background="@drawable/bg_btn_outline" />

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Pie decorativo -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="28dp"
            android:text="★  Chuankgames  ★"
            android:textColor="@color/secundario_alpha"
            android:textSize="11sp"
            android:fontFamily="@font/orangekid"
            android:letterSpacing="0.15" />

    </LinearLayout>

</ScrollView>
