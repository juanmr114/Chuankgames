<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/principal">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- Título -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Publicar juego"
            android:textColor="@color/secundario"
            android:textSize="26sp"
            android:textStyle="bold"
            android:fontFamily="@font/orangekid"
            android:layout_marginBottom="24dp" />

        <!-- Imagen del juego -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Portada del juego"
            android:textColor="@color/white"
            android:textSize="14sp"
            android:layout_marginBottom="8dp" />

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="180dp"
            android:layout_marginBottom="16dp">

            <ImageView
                android:id="@+id/ivPortadaSeleccionada"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:background="#1E2A38" />

            <TextView
                android:id="@+id/tvSeleccionarFoto"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:text="📷 Toca para seleccionar imagen"
                android:textColor="#AAAAAA"
                android:textSize="14sp" />

        </FrameLayout>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSeleccionarImagen"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Seleccionar imagen"
            android:textColor="@color/principal"
            android:backgroundTint="@color/secundario"
            android:layout_marginBottom="20dp"
            app:cornerRadius="10dp" />

        <!-- Nombre -->
        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Nombre del juego"
            android:layout_marginBottom="12dp"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            app:boxStrokeColor="@color/secundario"
            app:hintTextColor="@color/secundario">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etNombreJuego"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/white"
                android:inputType="textCapWords" />

        </com.google.android.material.textfield.TextInputLayout>

        <!-- Género -->
        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Género (Acción, RPG, Deportes...)"
            android:layout_marginBottom="12dp"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            app:boxStrokeColor="@color/secundario"
            app:hintTextColor="@color/secundario">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etGeneroJuego"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/white"
                android:inputType="textCapWords" />

        </com.google.android.material.textfield.TextInputLayout>

        <!-- Descripción -->
        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Descripción"
            android:layout_marginBottom="12dp"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            app:boxStrokeColor="@color/secundario"
            app:hintTextColor="@color/secundario">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etDescripcionJuego"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/white"
                android:inputType="textMultiLine"
                android:minLines="3"
                android:gravity="top" />

        </com.google.android.material.textfield.TextInputLayout>

        <!-- Precio -->
        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Precio (€)"
            android:layout_marginBottom="24dp"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            app:boxStrokeColor="@color/secundario"
            app:hintTextColor="@color/secundario">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etPrecioJuego"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/white"
                android:inputType="numberDecimal" />

        </com.google.android.material.textfield.TextInputLayout>

        <!-- Botón publicar -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnPublicarJuego"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Publicar juego"
            android:textColor="@color/principal"
            android:textSize="16sp"
            android:textStyle="bold"
            android:backgroundTint="@color/secundario"
            android:paddingVertical="14dp"
            app:cornerRadius="12dp" />

        <!-- Progress -->
        <ProgressBar
            android:id="@+id/progressPublicar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="16dp"
            android:visibility="gone" />

    </LinearLayout>

</androidx.core.widget.NestedScrollView>